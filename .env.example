DISCORD_TOKEN=put_your_new_discord_bot_token_here
GUILD_ID=1518702371428106290

# Optional AI. Leave AI_API_KEY blank to disable AI replies/summaries.
# NVIDIA NIM / build.nvidia.com example:
# AI_API_KEY=your_nvapi_key_here
# AI_BASE_URL=https://integrate.api.nvidia.com/v1
# AI_MODEL=minimaxai/minimax-m3
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

# Backward compatible names. Leave blank if using AI_* above.
OPENAI_API_KEY=
OPENAI_MODEL=

# Bot owner/admin Discord user IDs, comma separated. Example: 123,456
OWNER_IDS=1439166297496621117

# AI MCP agent mode. Put your Discord MCP HTTP/SSE endpoint here.
# Example values depend on how you run the MCP server.
DISCORD_MCP_URL=
MCP_GUILD_ID=1518702371428106290
AI_AGENT_PREFIX=!

# Safety defaults
MAX_MESSAGES_PER_10_SECONDS=7
MAX_MENTIONS_PER_MESSAGE=6
